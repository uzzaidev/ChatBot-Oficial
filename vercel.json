{
  "ignoreCommand": "git diff --quiet HEAD^ HEAD -- . ':!CHANGELOG.md'",
  "crons": [
    {
      "path": "/api/cron/inactivity-check",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/crm-executions-cleanup",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/crm-dlq-retry",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/crm-scheduled-actions",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/cron/enforce-grace-period",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/traces-reconcile",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/quality-daily-report",
      "schedule": "10 7 * * *"
    }
  ]
}
