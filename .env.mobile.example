# Environment Variables para Build Mobile
# Copie este arquivo para .env.mobile e preencha com valores reais
# Comando: cp .env.mobile.example .env.mobile

# =============================================================================
# SUPABASE (OBRIGATÓRIO)
# =============================================================================
# Obtenha em: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# =============================================================================
# AI SERVICES (OBRIGATÓRIO para funcionalidades de IA)
# =============================================================================

# OpenAI - Whisper (transcrição de áudio), GPT-4o Vision, Embeddings
# Obtenha em: https://platform.openai.com/api-keys
NEXT_PUBLIC_OPENAI_API_KEY=sk-...

# Groq - Llama 3.3 70B (chatbot principal)
# Obtenha em: https://console.groq.com/keys
NEXT_PUBLIC_GROQ_API_KEY=gsk_...

# =============================================================================
# WHATSAPP META API (OPCIONAL - se usado no client)
# =============================================================================
# Obtenha em: https://developers.facebook.com/apps/
# NEXT_PUBLIC_META_PHONE_NUMBER_ID=899639703222013
# NEXT_PUBLIC_META_ACCESS_TOKEN=EAA...

# =============================================================================
# APP CONFIGURATION (OPCIONAL)
# =============================================================================
# Ambiente de execução (development, staging, production)
NEXT_PUBLIC_ENV=production

# URL base da API (OBRIGATÓRIO para mobile - API routes não funcionam em static export)
# Mobile faz fetch para a API em produção
NEXT_PUBLIC_API_URL=https://uzzapp.uzzai.com.br

# =============================================================================
# FIREBASE (NECESSÁRIO para Push Notifications - Phase 3)
# =============================================================================
# Configuração será necessária quando implementar push notifications
# Ver: docs/app/PUSH_NOTIFICATIONS.md

# =============================================================================
# NOTAS IMPORTANTES
# =============================================================================
# 1. NUNCA commite o arquivo .env.mobile (com valores reais) ao Git
# 2. Use NEXT_PUBLIC_* para variáveis que precisam estar disponíveis no client
# 3. Variáveis sem NEXT_PUBLIC_ não funcionam em mobile (static export)
# 4. Após modificar, execute: npm run build:mobile && npm run cap:sync
# 5. Para produção, considere usar Doppler (ver docs/app/ENV_VARS.md)

# =============================================================================
# STRIPE CONNECT (NOVO)
# =============================================================================
# Chave secreta do backend Stripe.
# PLACEHOLDER: substitua por chave real em ambiente server-side.
STRIPE_SECRET_KEY=sk_live_...

# Chave publica para futuros usos client-side (Stripe.js).
# PLACEHOLDER: substitua por chave real em ambiente publico.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Secret do webhook V1 (assinaturas/pagamentos).
# PLACEHOLDER: configurar no Dashboard Stripe > Webhooks.
STRIPE_WEBHOOK_SECRET=whsec_...

# Secret do webhook V2 Thin Events (Connected Accounts).
# PLACEHOLDER: configurar no Dashboard Stripe > Webhooks > Connected accounts.
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_...

# Taxa da plataforma aplicada em checkout direto (0-100).
STRIPE_APPLICATION_FEE_PERCENT=10

# URL base da aplicacao web usada em success/cancel/return.
NEXT_PUBLIC_APP_URL=https://uzzapp.uzzai.com.br

# Stripe Platform (Contexto A - UzzAI cobrando seus clientes)
STRIPE_PLATFORM_PRICE_ID=price_1T9n2o4oGVf4uL6gpHjlCO8l
STRIPE_PLATFORM_PRODUCT_ID=prod_U839DGKHweCEa0
STRIPE_PLATFORM_SETUP_FEE_PRICE_ID=price_1T9n854oGVf4uL6gX0CL7qZC
STRIPE_PLATFORM_SETUP_FEE_PRODUCT_ID=prod_U83EZ8MEm5CrU0
STRIPE_PLATFORM_WEBHOOK_SECRET=whsec_...

# Identidade da plataforma no banco
UZZAI_PLATFORM_CLIENT_ID=00000000-0000-0000-0000-000000000099
UZZAI_ADMIN_EMAIL=admin@uzzai.com.br
